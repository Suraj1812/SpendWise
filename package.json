{
  "name": "spendwise",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "mobile": "npm --prefix mobile start",
    "android": "npm --prefix mobile run android",
    "ios": "npm --prefix mobile run ios",
    "server": "npm --prefix server run dev",
    "check:server": "npm --prefix server run check",
    "check:mobile": "npm --prefix mobile run typecheck",
    "export:android": "npm --prefix mobile run export:android",
    "check": "npm run check:server && npm run check:mobile"
  }
}
